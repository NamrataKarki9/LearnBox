# =============================================================================
# LearnBox Environment Configuration Template
# =============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control (add to .gitignore)
# =============================================================================

# ============ DATABASE CONFIGURATION ============
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:mypassword@localhost:5432/learnbox_db
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/learnbox_db

# ============ JWT CONFIGURATION ============
# Secret key for signing JWT tokens (use a strong random string)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# ============ CLOUDINARY CONFIGURATION ============
# For file uploads and cloud storage
# Sign up at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============ EMAIL CONFIGURATION ============
# For OTP verification and notifications
# Using Gmail: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM_NAME=LearnBox

# ============ LLM CONFIGURATION ============
# Choose ONE: Ollama (local) OR Groq (cloud)

# Option 1: Ollama (Local LLM)
# Install from: https://ollama.ai
# Models available: mistral, llama2, etc.
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Option 2: Groq (Cloud LLM - faster/better)
# Get API key from: https://console.groq.com
# GROQ_API_KEY=gsk_your-groq-api-key

# ============ SERVER CONFIGURATION ============
# Server port
PORT=5000

# Environment: development, staging, production
NODE_ENV=development

# ============ ADMIN CONFIGURATION (Optional) ============
# Default admin credentials (used for seeding)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword123!

# ============ SESSION CONFIGURATION (Optional) ============
# Session secret for AdminJS
SESSION_SECRET=your-session-secret-min-32-chars

# ============ CORS CONFIGURATION (Optional) ============
# Allowed origins for CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============ LOGGING (Optional) ============
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable request logging with Morgan
MORGAN_FORMAT=combined

# =============================================================================
# NOTES:
# - All required fields are marked with example values
# - Keep this file private - never commit it to version control
# - For production, use strong random values for secrets
# - Update DATABASE_URL with your PostgreSQL connection details
# - Configure either Ollama (local) or Groq (cloud) for LLM features
# - For Cloudinary, sign up and get your credentials from dashboard
# - For email, use app-specific password (not your regular password)
# =============================================================================
